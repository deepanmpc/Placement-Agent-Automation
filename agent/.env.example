NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# Keep these in your private local .env. Do not commit real nvapi keys.
NVIDIA_REASONING_API_KEY=replace-with-gpt-oss-key
NVIDIA_VISION_API_KEY=replace-with-llama-4-maverick-key
NVIDIA_PARSER_API_KEY=replace-with-nemotron-parse-key

# Optional fallback if all NVIDIA calls share one key.
NVIDIA_API_KEY=

NVIDIA_REASONING_MODEL=openai/gpt-oss-120b
NVIDIA_FALLBACK_MODEL=meta/llama-3.3-70b-instruct

VISION_VLM_MODEL=meta/llama-4-maverick-17b-128e-instruct
NEMOTRON_PARSER_MODEL=nvidia/nemotron-parse

# Hosted vision/parser enrichment is optional. Local mss + PaddleOCR still runs.
ENABLE_VISION_VLM=false
ENABLE_NEMOTRON_PARSER=false

NVIDIA_MAX_TOKENS=4096
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_STREAM=true
LLM_TIMEOUT=45
VISION_API_TIMEOUT=30
VISION_MAX_TOKENS=1024
MAX_AGENT_ITERATIONS=10
