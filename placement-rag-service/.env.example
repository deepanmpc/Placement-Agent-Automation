# Service Configuration
RAG_COLLECTION_PREFIX=rag_
RAG_TOP_K_RETRIEVAL=10
RAG_TOP_K_RERANK=5

# API Configuration
RAG_HOST=0.0.0.0
RAG_PORT=8001
RAG_LOG_LEVEL=INFO
